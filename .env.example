# --- TriageVanta environment ---

# Session signing secret (REQUIRED). Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-32-plus-character-random-string"

# PostgreSQL connection string (OPTIONAL for local dev).
# Leave UNSET to use the embedded PGlite database at ./.pglite (no Docker needed).
#
# Local Docker Compose (see docker-compose.yml):
#   DATABASE_URL="postgres://triagevanta:triagevanta@localhost:5432/triagevanta"
#
# Managed Postgres (e.g. Neon) — append ?sslmode=require:
#   DATABASE_URL="postgres://user:pass@host.neon.tech/triagevanta?sslmode=require"
# DATABASE_URL=
